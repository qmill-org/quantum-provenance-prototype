        {
            "id": "results.measurement_counts",
            "value_pointer": "/results/measurement_counts",
            "evidence_pointer": "/results/measurement_counts",
            "applicability": {
                "not_applicable": [
                    "ionq"
                ]
            },
            "rationale": "measurement_counts holds actual provider-returned/observed integer counts. IonQ returns a probability histogram rather than observed counts, so this attribute is not applicable to IonQ records."
        },
        {
            "id": "results.measurement_probabilities",
            "value_pointer": "/results/measurement_probabilities",
            "evidence_pointer": "/results/measurement_probabilities",
            "applicability": {
                "applicable_only": [
                    "ionq"
                ]
            },
            "rationale": "Only IonQ exposes a provider-supplied probability histogram in this prototype; Braket and IBM return observed counts."
        },
        {
            "id": "results.estimated_measurement_counts",
            "value_pointer": "/results/estimated_measurement_counts",
            "evidence_pointer": "/results/estimated_measurement_counts",
            "applicability": {
                "applicable_only": [
                    "ionq"
                ]
            },
            "rationale": "Optional counts derived from provider-supplied probabilities and requested shots; not observed counts."
        },
