{
    "inventory_version": "0.1.0",
    "schema_version": "0.1.0-prototype",
    "description": "Fixed, versioned inventory of provenance attributes evaluated for every provider record. Each attribute is classified per provider as exactly one of the evidence-qualifier statuses (provider_supplied, aggregator_normalized, provider_passthrough, derived, application_captured, unavailable, not_applicable, not_verifiable) or, when an emitted attribute has no classification, unclassified (which fails the evaluation). Classification distinguishes an absent-but-applicable field (unavailable) from an inapplicable field (not_applicable). This inventory enumerates canonical attributes; it is intentionally separate from the count of raw evidence entries in a record.",
    "statuses": [
        "provider_supplied",
        "aggregator_normalized",
        "provider_passthrough",
        "derived",
        "application_captured",
        "unavailable",
        "not_applicable",
        "not_verifiable",
        "unclassified"
    ],
    "attributes": [
        {
            "id": "job.status",
            "value_pointer": "/job/status",
            "evidence_pointer": "/job/status",
            "applicability": "all"
        },
